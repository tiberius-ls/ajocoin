# Vercel KV or Upstash Redis (Storage integration in Vercel dashboard)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional: override Nimiq JSON-RPC for on-chain tx verification
NIMIQ_RPC_URL=https://rpc.nimiq.network

# Client: set to "false" only for local UI dev without a shared store
VITE_USE_SHARED_STORE=true